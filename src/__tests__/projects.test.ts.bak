import { describe, it, expect, beforeAll, afterAll, afterEach } from 'vitest'
import { Scaffald } from '../client.js'
import { server } from './mocks/server.js'
import { http, HttpResponse } from 'msw'

describe('Projects', () => {
  let client: Scaffald

  beforeAll(() => {
    server.listen({ onUnhandledRequest: 'error' })
    client = new Scaffald({
      apiKey: 'test_key',
      baseUrl: 'https://api.scaffald.com',
    })
  })

  afterEach(() => {
    server.resetHandlers()
  })

  afterAll(() => {
    server.close()
  })

  // ===== List Projects =====

  describe('list()', () => {
    it('should list projects', async () => {
      const result = await client.projects.list()

      expect(result).toBeDefined()
      expect(result.projects).toBeInstanceOf(Array)
      expect(result.count).toBeDefined()
    })

    it('should filter projects by organization', async () => {
      const result = await client.projects.list({
        organizationId: 'org_123',
      })

      expect(result).toBeDefined()
      expect(result.projects).toBeInstanceOf(Array)
    })

    it('should filter projects by status', async () => {
      const result = await client.projects.list({
        status: 'active',
      })

      expect(result).toBeDefined()
      expect(result.projects).toBeInstanceOf(Array)
    })

    it('should support pagination', async () => {
      const result = await client.projects.list({
        limit: 10,
        offset: 0,
      })

      expect(result).toBeDefined()
      expect(result.projects.length).toBeLessThanOrEqual(10)
    })
  })

  // ===== Get Project by ID =====

  describe('getById()', () => {
    it('should get project by ID', async () => {
      const result = await client.projects.getById({ id: 'project_123' })

      expect(result).toBeDefined()
      expect(result.id).toBe('project_123')
    })

    it('should include project sites', async () => {
      const result = await client.projects.getById({ id: 'project_123' })

      expect(result.project_sites).toBeDefined()
      expect(result.project_sites).toBeInstanceOf(Array)
    })

    it('should include project addresses', async () => {
      const result = await client.projects.getById({ id: 'project_123' })

      expect(result.project_addresses).toBeDefined()
      expect(result.project_addresses).toBeInstanceOf(Array)
    })

    it('should include project workers', async () => {
      const result = await client.projects.getById({ id: 'project_123' })

      expect(result.project_workers).toBeDefined()
      expect(result.project_workers).toBeInstanceOf(Array)
    })

    it('should handle nonexistent project', async () => {
      server.use(
        http.get('*/projects/:id', () => {
          return HttpResponse.json({ error: 'Project not found' }, { status: 404 })
        })
      )

      await expect(client.projects.getById({ id: 'invalid' })).rejects.toThrow()
    })
  })

  // ===== Create Project =====

  describe('create()', () => {
    it('should create a project', async () => {
      const result = await client.projects.create({
        organizationId: 'org_123',
        name: 'New Construction Project',
        description: 'A major construction project',
        status: 'planning',
      })

      expect(result).toBeDefined()
      expect(result.id).toBeDefined()
      expect(result.name).toBe('New Construction Project')
      expect(result.organization_id).toBe('org_123')
    })

    it('should create project with minimal params', async () => {
      const result = await client.projects.create({
        organizationId: 'org_456',
        name: 'Simple Project',
      })

      expect(result).toBeDefined()
      expect(result.name).toBe('Simple Project')
    })

    it('should create project with dates', async () => {
      const result = await client.projects.create({
        organizationId: 'org_123',
        name: 'Scheduled Project',
        startDate: '2024-01-01',
        endDate: '2024-12-31',
      })

      expect(result).toBeDefined()
      expect(result.start_date).toBeDefined()
      expect(result.end_date).toBeDefined()
    })

    it('should create project with location visibility', async () => {
      const result = await client.projects.create({
        organizationId: 'org_123',
        name: 'Private Location Project',
        locationVisibility: 'private',
        locationVisibilityOverride: true,
      })

      expect(result).toBeDefined()
      expect(result.location_visibility).toBe('private')
    })
  })

  // ===== Update Project =====

  describe('update()', () => {
    it('should update a project', async () => {
      const result = await client.projects.update({
        id: 'project_123',
        name: 'Updated Project Name',
        status: 'active',
      })

      expect(result).toBeDefined()
      expect(result.id).toBe('project_123')
    })

    it('should update project dates', async () => {
      const result = await client.projects.update({
        id: 'project_123',
        startDate: '2024-02-01',
        endDate: '2024-11-30',
      })

      expect(result).toBeDefined()
    })

    it('should clear optional fields with null', async () => {
      const result = await client.projects.update({
        id: 'project_123',
        description: null,
        startDate: null,
        endDate: null,
      })

      expect(result).toBeDefined()
    })
  })

  // ===== Add Site =====

  describe('addSite()', () => {
    it('should add a site to project', async () => {
      const result = await client.projects.addSite({
        projectId: 'project_123',
        siteId: 'site_456',
        isPrimary: true,
      })

      expect(result).toBeDefined()
      expect(result.project_site).toBeDefined()
      expect(result.overlaps).toBeInstanceOf(Array)
    })

    it('should include overlap information', async () => {
      const result = await client.projects.addSite({
        projectId: 'project_123',
        siteId: 'site_789',
      })

      expect(result.overlaps).toBeDefined()
      expect(result.overlaps).toBeInstanceOf(Array)
    })
  })

  // ===== Add Address =====

  describe('addAddress()', () => {
    it('should add an address to project', async () => {
      const result = await client.projects.addAddress({
        projectId: 'project_123',
        addressId: 'address_456',
        isPrimary: true,
      })

      expect(result).toBeDefined()
      expect(result.project_address).toBeDefined()
    })
  })

  // ===== Worker Management =====

  describe('addWorker()', () => {
    it('should add a worker to project', async () => {
      const result = await client.projects.addWorker({
        projectId: 'project_123',
        userId: 'user_456',
        jobId: 'job_789',
        roleOnProject: 'Foreman',
      })

      expect(result).toBeDefined()
      expect(result.id).toBeDefined()
      expect(result.user_id).toBe('user_456')
      expect(result.assigned_by_manager).toBe(true)
    })

    it('should add worker with dates', async () => {
      const result = await client.projects.addWorker({
        projectId: 'project_123',
        userId: 'user_456',
        startDate: '2024-01-01',
        endDate: '2024-06-30',
      })

      expect(result).toBeDefined()
      expect(result.start_date).toBeDefined()
    })
  })

  describe('claimWork()', () => {
    it('should claim work on project', async () => {
      const result = await client.projects.claimWork({
        projectId: 'project_123',
        roleOnProject: 'Electrician',
        notes: 'Worked on electrical installation',
      })

      expect(result).toBeDefined()
      expect(result.id).toBeDefined()
      expect(result.claimed_by_worker).toBe(true)
      expect(result.status).toBe('pending')
    })
  })

  describe('approveWorker()', () => {
    it('should approve a worker claim', async () => {
      const result = await client.projects.approveWorker({
        projectWorkerId: 'worker_123',
      })

      expect(result).toBeDefined()
      expect(result.id).toBe('worker_123')
      expect(result.status).toBe('approved')
    })
  })

  describe('rejectWorker()', () => {
    it('should reject a worker claim', async () => {
      const result = await client.projects.rejectWorker({
        projectWorkerId: 'worker_456',
        reason: 'Incorrect dates',
      })

      expect(result).toBeDefined()
      expect(result.id).toBe('worker_456')
      expect(result.status).toBe('rejected')
    })
  })

  // ===== Error Handling =====

  describe('error handling', () => {
    it('should handle authentication errors', async () => {
      server.use(
        http.get('*/projects', () => {
          return HttpResponse.json({ error: 'Unauthorized' }, { status: 401 })
        })
      )

      await expect(client.projects.list()).rejects.toThrow()
    })

    it('should handle rate limiting', { timeout: 15000 }, async () => {
      server.use(
        http.get('*/projects', () => {
          return HttpResponse.json(
            { error: 'Rate limit exceeded' },
            { status: 429, headers: { 'Retry-After': '60' } }
          )
        })
      )

      await expect(client.projects.list()).rejects.toThrow()
    })

    it('should handle server errors', async () => {
      server.use(
        http.post('*/projects', () => {
          return HttpResponse.json(
            { error: 'Internal server error' },
            { status: 500 }
          )
        })
      )

      await expect(
        client.projects.create({
          organizationId: 'org_1',
          name: 'Test',
        })
      ).rejects.toThrow()
    })

    it('should validate required fields', async () => {
      server.use(
        http.post('*/projects', () => {
          return HttpResponse.json(
            { error: 'organizationId is required' },
            { status: 400 }
          )
        })
      )

      await expect(
        client.projects.create({
          organizationId: '',
          name: 'Test',
        })
      ).rejects.toThrow()
    })
  })
})
