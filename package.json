{
  "name": "@scaffald/sdk",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript SDK for the Scaffald API",
  "author": "Scaffald <dev@scaffald.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Unicorn/UNI-Construct.git",
    "directory": "packages/scaffald-sdk"
  },
  "keywords": [
    "scaffald",
    "api",
    "sdk",
    "jobs",
    "recruiting",
    "oauth",
    "typescript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate:types": "tsx scripts/generate-types.ts",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.17.9",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "msw": "^2.0.11",
    "openapi-typescript": "^6.7.3",
    "react": "^18.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "@tanstack/react-query": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
