{
  "name": "@scaffald/sdk",
  "version": "0.3.0",
  "description": "Official JavaScript/TypeScript SDK for the Scaffald API",
  "keywords": [
    "scaffald",
    "api",
    "sdk",
    "jobs",
    "recruiting",
    "oauth",
    "typescript"
  ],
  "homepage": "https://scaffald.github.io/sdk/",
  "bugs": {
    "url": "https://github.com/Scaffald/sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Scaffald/sdk.git"
  },
  "license": "MIT",
  "author": "Scaffald <dev@scaffald.com>",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./resources/*": {
      "types": "./src/resources/*.ts",
      "import": "./src/resources/*.ts"
    },
    "./types/*": {
      "types": "./src/types/*.ts",
      "import": "./src/types/*.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "docs:build": "cd docs-site && npm run build",
    "docs:dev": "cd docs-site && npm start",
    "docs:serve": "cd docs-site && npm run serve",
    "generate:types": "tsx scripts/generate-types.ts",
    "lint": "biome lint src scripts",
    "lint:fix": "biome lint --write src scripts",
    "prepublishOnly": "pnpm build && pnpm test",
    "prerelease": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "release:dry": "npm publish --dry-run",
    "size": "size-limit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^11.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^9.2.6",
    "@semantic-release/npm": "^11.0.2",
    "@semantic-release/release-notes-generator": "^12.1.0",
    "@supabase/supabase-js": "catalog:",
    "@tanstack/react-query": "^5.17.9",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.10.6",
    "@types/react": "~19.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^23.0.1",
    "msw": "^2.12.8",
    "openapi-typescript": "^6.7.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "semantic-release": "^23.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "undici": ">=7.24.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
